<?xml version="1.0" encoding="utf-8"?>
<policy>
    <fullPath>/Common/positive-security</fullPath>
    <enforcementMode>blocking</enforcementMode>
    <encoding>utf-8</encoding>
    <signatureSettings>
        <signatureStaging>false</signatureStaging>
        <stagingPeriod>7</stagingPeriod>
        <placeholderSignaturesSettings>
            <placeholderSignatureSetting>
                <accuracyFilter>ge</accuracyFilter>
                <accuracyValue>medium</accuracyValue>
            </placeholderSignatureSetting>
        </placeholderSignaturesSettings>
        <threatCampaigns>false</threatCampaigns>
    </signatureSettings>
    <signatures></signatures>
    <signature-sets></signature-sets>
    <violations>
        <violation>
            <name>VIOL_ATTACK_SIGNATURE</name>
            <alarm>true</alarm>
            <block>true</block>
        </violation>
    </violations>
    <urls>
        <url>
            <name>/api/v1/users</name>
            <protocol>https</protocol>
            <type>explicit</type>
            <method>GET</method>
            <isAllowed>true</isAllowed>
            <attackSignaturesCheck>true</attackSignaturesCheck>
            <metacharsOnUrlCheck>true</metacharsOnUrlCheck>
            <clickjackingProtection>false</clickjackingProtection>
            <performStaging>false</performStaging>
        </url>
        <url>
            <name>/api/v1/orders</name>
            <protocol>https</protocol>
            <type>explicit</type>
            <method>POST</method>
            <isAllowed>true</isAllowed>
            <attackSignaturesCheck>true</attackSignaturesCheck>
            <metacharsOnUrlCheck>true</metacharsOnUrlCheck>
            <clickjackingProtection>false</clickjackingProtection>
            <performStaging>false</performStaging>
        </url>
        <url>
            <name>/admin/dashboard</name>
            <protocol>https</protocol>
            <type>explicit</type>
            <method>GET</method>
            <isAllowed>true</isAllowed>
            <attackSignaturesCheck>true</attackSignaturesCheck>
            <metacharsOnUrlCheck>true</metacharsOnUrlCheck>
            <clickjackingProtection>true</clickjackingProtection>
            <performStaging>false</performStaging>
        </url>
        <url>
            <name>/static/*</name>
            <type>wildcard</type>
            <isAllowed>true</isAllowed>
            <attackSignaturesCheck>false</attackSignaturesCheck>
        </url>
        <url>
            <name>/api/v2/*</name>
            <type>wildcard</type>
            <isAllowed>true</isAllowed>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </url>
    </urls>
    <parameters>
        <parameter>
            <name>first_name</name>
            <type>explicit</type>
            <valueType>alpha</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
            <allowEmptyValue>false</allowEmptyValue>
            <checkMaxValueLength>true</checkMaxValueLength>
            <maximumLength>100</maximumLength>
        </parameter>
        <parameter>
            <name>last_name</name>
            <type>explicit</type>
            <valueType>alpha</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>age</name>
            <type>explicit</type>
            <valueType>numeric</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>email_address</name>
            <type>explicit</type>
            <valueType>email</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>comment</name>
            <type>explicit</type>
            <valueType>user-input</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>search_query</name>
            <type>explicit</type>
            <valueType>auto-detect</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>password</name>
            <type>explicit</type>
            <valueType>user-input</valueType>
            <level>global</level>
            <sensitiveParameter>true</sensitiveParameter>
            <attackSignaturesCheck>false</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>token</name>
            <type>explicit</type>
            <valueType>auto-detect</valueType>
            <level>global</level>
            <sensitiveParameter>true</sensitiveParameter>
            <attackSignaturesCheck>false</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>page_num</name>
            <type>explicit</type>
            <valueType>numeric</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>sort_by</name>
            <type>explicit</type>
            <valueType>alpha</valueType>
            <level>global</level>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
    </parameters>
    <filetypes>
        <filetype>
            <name>pdf</name>
            <allowed>true</allowed>
            <responseCheck>false</responseCheck>
            <queryStringLength>2048</queryStringLength>
            <urlLength>4096</urlLength>
            <postDataLength>65536</postDataLength>
            <requestLength>131072</requestLength>
        </filetype>
        <filetype>
            <name>jpg</name>
            <allowed>true</allowed>
            <responseCheck>false</responseCheck>
            <queryStringLength>1024</queryStringLength>
            <urlLength>2048</urlLength>
            <postDataLength>10485760</postDataLength>
            <requestLength>10485760</requestLength>
        </filetype>
        <filetype>
            <name>exe</name>
            <allowed>false</allowed>
            <responseCheck>false</responseCheck>
        </filetype>
    </filetypes>
    <cookies>
        <cookie>
            <name>session_token</name>
            <type>explicit</type>
            <enforcementType>allow</enforcementType>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </cookie>
        <cookie>
            <name>preferences</name>
            <type>wildcard</type>
            <enforcementType>enforce</enforcementType>
            <attackSignaturesCheck>false</attackSignaturesCheck>
        </cookie>
    </cookies>
    <headers>
        <header>
            <name>X-Custom-Auth</name>
            <type>explicit</type>
            <mandatory>true</mandatory>
            <checkSignatures>true</checkSignatures>
        </header>
        <header>
            <name>X-Request-ID</name>
            <type>explicit</type>
            <mandatory>false</mandatory>
            <checkSignatures>false</checkSignatures>
        </header>
    </headers>
    <methods>
        <method>
            <name>GET</name>
        </method>
        <method>
            <name>POST</name>
        </method>
    </methods>
    <whitelist-ips></whitelist-ips>
    <custom-signatures>
        <custom-signature>
            <id>1001</id>
            <name>Custom SQL Injection Pattern</name>
            <pattern><![CDATA[(?i)\b(?:union\s+all\s+select|drop\s+table)\b]]></pattern>
            <scope>url</scope>
        </custom-signature>
        <custom-signature>
            <id>1002</id>
            <name>Custom XSS Pattern</name>
            <pattern><![CDATA[<script[^>]*>.*?</script>]]></pattern>
            <scope>parameter</scope>
        </custom-signature>
    </custom-signatures>
</policy>
