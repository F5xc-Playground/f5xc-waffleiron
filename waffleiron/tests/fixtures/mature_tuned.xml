<?xml version="1.0" encoding="utf-8"?>
<policy>
    <fullPath>/Common/mature-tuned</fullPath>
    <enforcementMode>blocking</enforcementMode>
    <encoding>utf-8</encoding>
    <signatureSettings>
        <signatureStaging>true</signatureStaging>
        <stagingPeriod>7</stagingPeriod>
        <placeholderSignaturesSettings>
            <placeholderSignatureSetting>
                <accuracyFilter>ge</accuracyFilter>
                <accuracyValue>medium</accuracyValue>
            </placeholderSignatureSetting>
        </placeholderSignaturesSettings>
        <threatCampaigns>true</threatCampaigns>
    </signatureSettings>
    <signatures>
        <signature>
            <signatureId>200001001</signatureId>
            <enabled>true</enabled>
            <alarm>true</alarm>
            <block>false</block>
        </signature>
        <signature>
            <signatureId>200001002</signatureId>
            <enabled>false</enabled>
            <alarm>false</alarm>
            <block>false</block>
        </signature>
        <signature>
            <signatureId>200001003</signatureId>
            <enabled>true</enabled>
            <alarm>true</alarm>
            <block>true</block>
        </signature>
    </signatures>
    <signature-sets></signature-sets>
    <violations>
        <violation>
            <name>VIOL_COOKIE_MODIFIED</name>
            <alarm>true</alarm>
            <block>false</block>
        </violation>
        <violation>
            <name>VIOL_ENCODING</name>
            <alarm>true</alarm>
            <block>false</block>
        </violation>
        <violation>
            <name>VIOL_ATTACK_SIGNATURE</name>
            <alarm>true</alarm>
            <block>true</block>
        </violation>
    </violations>
    <urls>
        <url>
            <name>/api/v1/data</name>
            <type>explicit</type>
            <attackSignaturesCheck>false</attackSignaturesCheck>
        </url>
        <url>
            <name>/login</name>
            <type>explicit</type>
            <attackSignaturesCheck>true</attackSignaturesCheck>
            <signatureOverrides>
                <signatureOverride>
                    <signatureId>200001004</signatureId>
                    <enabled>false</enabled>
                    <alarm>false</alarm>
                    <block>false</block>
                </signatureOverride>
            </signatureOverrides>
        </url>
    </urls>
    <parameters>
        <parameter>
            <name>session_id</name>
            <sensitiveParameter>true</sensitiveParameter>
            <attackSignaturesCheck>true</attackSignaturesCheck>
        </parameter>
        <parameter>
            <name>query</name>
            <sensitiveParameter>false</sensitiveParameter>
            <attackSignaturesCheck>false</attackSignaturesCheck>
        </parameter>
    </parameters>
    <filetypes></filetypes>
    <cookies>
        <cookie>
            <name>tracking</name>
            <attackSignaturesCheck>false</attackSignaturesCheck>
        </cookie>
    </cookies>
    <headers></headers>
    <methods></methods>
    <whitelist-ips>
        <ip>
            <ipAddress>10.0.0.0</ipAddress>
            <ipMask>255.0.0.0</ipMask>
            <blockRequests>never</blockRequests>
        </ip>
    </whitelist-ips>
    <geolocation-enforcement>
        <disallowed-geolocations>
            <geolocation>
                <country>North Korea</country>
            </geolocation>
            <geolocation>
                <country>Iran</country>
            </geolocation>
        </disallowed-geolocations>
    </geolocation-enforcement>
    <bot-defense>
        <enabled>true</enabled>
        <mode>during-attacks</mode>
        <categories>
            <category>
                <name>malicious-bot</name>
                <action>block</action>
            </category>
            <category>
                <name>benign-bot</name>
                <action>report</action>
            </category>
            <category>
                <name>unknown-bot</name>
                <action>challenge</action>
            </category>
        </categories>
    </bot-defense>
    <blocking-page>
        <enabled>true</enabled>
        <responseCode>403</responseCode>
        <customHtml><![CDATA[<html><body><h1>Blocked</h1><p>Request ID: <%TS.request.ID()%></p></body></html>]]></customHtml>
    </blocking-page>
</policy>
